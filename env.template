# /docker/wa-webhook-sbsr/.env — bridge-side env.
# Copy this to that path on the VPS, fill in REPLACE values, NEVER commit.

# === Bridge ============================================================
PORT=3002
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=45920
OPENCLAW_TOKEN=REPLACE-WITH-32-HEX-TOKEN

# === Meta / WhatsApp Cloud API =========================================
WA_API_VERSION=v22.0
META_APP_SECRET=REPLACE
VERIFY_TOKEN=REPLACE-RANDOM-32

# === Postgres =========================================
POSTGRES_URL=postgresql://sbsr:CHANGE_ME@127.0.0.1:5432/sbsr
# Conversation retention: max days to keep messages (default 90)
WA_MSG_RETENTION_DAYS=90
# Max messages stored per phone number in PostgreSQL (default 500)
WA_MSG_MAX_PER_PHONE=500
REDIS_URL=redis://127.0.0.1:6379
QDRANT_URL=http://127.0.0.1:6333

# Three phones, same WABA, same access token
WA_BUSINESS_ACCOUNT_ID=REPLACE
WA_PHONE_NUMBER_ID_CS=REPLACE
WA_PHONE_NUMBER_ID_FINANCE=REPLACE
WA_PHONE_NUMBER_ID_KITCHEN=REPLACE
WA_ACCESS_TOKEN=REPLACE

# Catalog (if used to render product picker via WhatsApp catalog)
WA_CATALOG_ID=

# === Routing logic (consumed by patched bridge code) ===================
SBSR_FINANCE_PHONES=
SBSR_KITCHEN_PHONES=
SBSR_OPS_ESCALATION_PHONE=

# === Operating hours ===================================================
SBSR_HOURS_OPEN=08:00
SBSR_HOURS_CLOSE=20:00

# === Admin inbox (Stage 3+) ============================================
ADMIN_PASSWORD=

# === Biteship webhook (status updates from couriers) ===================
# Bridge verifies inbound signature against this secret before forwarding
# the status to sentuh-tracking-followup.mjs.
BITESHIP_WEBHOOK_SECRET=REPLACE

# === OCR (called by bridge when payment proof arrives) =================
OPENROUTER_API_KEY=sk-or-v1-REPLACE
# OPENAI_API_KEY=  ← keep unset (footgun, see handover docs)

# === Sheet (some bridge paths write directly via GAS) ==================
GSHEET_GAS_URL=https://script.google.com/macros/s/AKfycbyO6VtnMxfRmi_HqGF_ZB68KBI8co1vOJHJc7hbLG5LkNdpgkL80sszymQhu-N2xKs/exec
